{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "EDITOR": "vim",
    "PYTHONDONTWRITEBYTECODE": "1",
    "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
    "CMAKE_COLOR_DIAGNOSTICS": "ON",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "250000",
    "CLAUDE_CODE_HIDE_CWD": "1"
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Bash(cloc *)",
      "Bash(cmake *)",
      "Bash(ctest *)",
      "Bash(ldd *)",
      "Bash(module *)",
      "Bash(nm *)",
      "Bash(objdump *)",
      "Bash(pprof *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git cherry-pick *)",
      "Bash(git reset *)",
      "Bash(git stash *)",
      "Bash(git clang-format *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh run watch *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr create *)",
      "Bash(gh issue view *)"
    ],
    "deny": [
      "Edit(~/.ssh/**)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)"
    ],
    "defaultMode": "auto",
    "additionalDirectories": [
      "/home/wentzell/Dropbox/Coding",
      "~/opt"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh done"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh error"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh busy"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh done"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh clear"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh input"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh busy"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh input"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-status.sh busy"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": false
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "theme": "dark-ansi",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
