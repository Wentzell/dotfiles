#!/bin/bash
# Cycle through tmux panes running Claude Code in the current session.
# Usage: tmux-next-claude [--prev]

dir=1
[ "$1" = "--prev" ] && dir=-1

current_pane=$(tmux display-message -p '#{pane_id}')

# Build set of PIDs that are parents of a "claude" process (single pgrep, /proc reads)
declare -A claude_ppids
for pid in $(pgrep -x claude 2>/dev/null); do
    read -r ppid < /proc/$pid/stat 2>/dev/null || continue
    ppid=${ppid#*) ? }; ppid=${ppid%% *}
    [[ $ppid =~ ^[0-9]+$ ]] && claude_ppids[$ppid]=1
done

# Get all panes, find claude panes and current index
claude_panes=()
cur_idx=-1
idx=0
while IFS=$'\t' read -r pane_id pane_pid; do
    [ "$pane_id" = "$current_pane" ] && cur_idx=$idx
    [ "${claude_ppids[$pane_pid]+x}" ] && claude_panes+=("$idx:$pane_id")
    ((idx++))
done < <(tmux list-panes -s -F '#{pane_id}	#{pane_pid}')

nc=${#claude_panes[@]}
[ "$nc" -eq 0 ] && { tmux display-message "No Claude panes found"; exit 0; }

# Find nearest Claude pane in the chosen direction (wrap around)
if [ "$dir" -eq 1 ]; then
    target="${claude_panes[0]}"
    for entry in "${claude_panes[@]}"; do
        [ "${entry%%:*}" -gt "$cur_idx" ] && { target="$entry"; break; }
    done
else
    target="${claude_panes[$((nc - 1))]}"
    for ((k = nc - 1; k >= 0; k--)); do
        [ "${claude_panes[$k]%%:*}" -lt "$cur_idx" ] && { target="${claude_panes[$k]}"; break; }
    done
fi

pane="${target#*:}"
tmux select-window -t "$pane"
tmux select-pane -t "$pane"
